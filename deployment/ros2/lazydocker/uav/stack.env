# - defines the name for the docker compose session
# - rosbags are placed to /home/$DRONE_USER_NAME/docker/$SESSION_NAME/bag_files
# - terminal logs are placed to /home/$DRONE_USER_NAME/docker/$SESSION_NAME/logs
SESSION_NAME=just_flying
DRONE_USER_NAME=mrs
RUN_TYPE=realworld
UAV_NAME=uav30
UAV_TYPE=x500
UAV_MASS=4.0
MRS_UAV_SYSTEM_VERSION=stable
WORLD_NAME=temesvar_field
OLD_PX4_FW=false
RMW_IMPLEMENTATION=rmw_zenoh_cpp
